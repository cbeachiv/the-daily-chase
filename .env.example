# Copy to .env.local and fill in. Never commit .env.local.

ANTHROPIC_API_KEY=
RESEND_API_KEY=
RECAP_EMAIL=chasetbeach@gmail.com
RENR_TO=                    # "Reps & Repositories" recipient (Gino). Falls back to RECAP_EMAIL.
RENR_CC=                    # "Reps & Repositories" CC (comma-separated). e.g. chasetbeach@gmail.com
GOGGINS_TO=                 # Daily 4:15pm "Stay Hard" recipient. Falls back to RECAP_EMAIL.
FINANCE_TO=                 # Finance recap recipient (Chase). The monthly draft goes here ONLY;
                            # the approved final goes here (To) + FINANCE_CC. Falls back to RECAP_EMAIL.
FINANCE_CC=                 # Monthly final CC (comma-separated) — Sarah's email. Only added after Chase approves.
REVIEW_TO=                  # Daily 4:30pm "The Daily Review" recipient. Falls back to RECAP_EMAIL.
RESEND_FROM="The Daily Chase <onboarding@resend.dev>"
ADVISOR_FROM=               # Monthly recap "from" — the advisor persona, e.g.
                            # "Daniela Reyes <advisor@thedailychase.com>". Domain must be
                            # verified in Resend. Falls back to RESEND_FROM.
FX_USD_MXN_FALLBACK=        # USD→MXN rate used if the live FX fetch fails (default 18.5).
SARAH_EMAIL=                # Sarah's email — allowed to log Sarah Beach Interiors hours by email.
RESEND_WEBHOOK_SECRET=      # Svix signing secret for the Resend inbound webhook (/api/interiors/hours).
APP_BASE_URL=https://thedailychase.com  # Base URL for links in emails (e.g. the /review button).
CRON_SECRET=
GITHUB_TOKEN=
GATE_PASSWORD=chase

# Plaid (bank/card sync). Keys from dashboard.plaid.com → Developers → Keys.
PLAID_CLIENT_ID=
PLAID_SECRET=                # use the Sandbox secret first, then Production
PLAID_ENV=sandbox           # sandbox | production
PLAID_REDIRECT_URI=         # Production only: the page hosting Link, e.g.
                            # https://thedailychase.com/finance — must be
                            # registered in Plaid dashboard → Developers → API
FINANCE_SELF_NAMES=         # Account holder name(s), comma-separated (e.g.
                            # "Charles Beach,Chase Beach"). Deposits naming you are
                            # treated as internal transfers, not income.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
